# -----------------------------------------------------------------------------
# Ralu Norvegia — Landing site Firebase configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and keep it out of version control.
# Vite only exposes variables prefixed with VITE_ to the client bundle.
#
# These values are the WEB app credentials of the `ralunorvegia` Firebase
# project (see /lib/firebase_options.dart in the Flutter app). Firebase web API
# keys are not secrets — access is controlled by Firestore/Storage security
# rules — but keeping them in .env makes it easy to swap projects per env.

VITE_FIREBASE_API_KEY=AIzaSyBHWgucuXfqfClcu738fXH1zT_GpTKrdhM
VITE_FIREBASE_AUTH_DOMAIN=ralunorvegia.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ralunorvegia
VITE_FIREBASE_STORAGE_BUCKET=ralunorvegia.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=775850665665
VITE_FIREBASE_APP_ID=1:775850665665:web:1c78adf7f69ab8e8f7d640
VITE_FIREBASE_MEASUREMENT_ID=G-5KXERDYQPM
