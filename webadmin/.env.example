# -----------------------------------------------------------------------------
# Ralu Norvegia — Admin dashboard Firebase configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` (or `.env.local`) and keep it out of version control.
# Only variables prefixed with VITE_ are exposed to the client bundle.
#
# These are the WEB app credentials of the `ralunorvegia` Firebase project
# (mirrors /lib/firebase_options.dart in the Flutter app). The web API key is
# NOT a secret — admin access is enforced by Firebase Auth + Firestore security
# rules that check the signed-in user's `role`/`isAdmin` field.

VITE_FIREBASE_API_KEY=AIzaSyBHWgucuXfqfClcu738fXH1zT_GpTKrdhM
VITE_FIREBASE_AUTH_DOMAIN=ralunorvegia.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ralunorvegia
VITE_FIREBASE_STORAGE_BUCKET=ralunorvegia.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=775850665665
VITE_FIREBASE_APP_ID=1:775850665665:web:1c78adf7f69ab8e8f7d640
