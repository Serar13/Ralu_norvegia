{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "ralunorvegia",
          "appId": "1:775850665665:android:bd99a46ca9a39f6af7d640",
          "fileOutput": "app/android/app/google-services.json"
        }
      },
      "dart": {
        "app/lib/firebase_options.dart": {
          "projectId": "ralunorvegia",
          "configurations": {
            "android": "1:775850665665:android:bd99a46ca9a39f6af7d640",
            "ios": "1:775850665665:ios:69dc87772a4394ecf7d640",
            "macos": "1:775850665665:ios:69dc87772a4394ecf7d640",
            "web": "1:775850665665:web:1c78adf7f69ab8e8f7d640",
            "windows": "1:775850665665:web:dfe17902e30b6cddf7d640"
          }
        }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": [
    {
      "target": "site",
      "public": "site/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }],
      "headers": [
        {
          "source": "**/*.@(js|css|svg|png|jpg|jpeg|gif|webp|woff|woff2)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        }
      ]
    },
    {
      "target": "webadmin",
      "public": "webadmin/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }],
      "headers": [
        {
          "source": "**/*.@(js|css|svg|png|jpg|jpeg|gif|webp|woff|woff2)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        }
      ]
    }
  ]
}
